# ============================================
# iMonitorServer - Test Environment
# ============================================
# Copy this file to .env.test and fill in real values

# --- Application ---
NODE_ENV=test
APP_PORT=3099
APP_URL=http://localhost:3099
FRONTEND_URL=http://localhost:8099

# --- Database (PostgreSQL) ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=imonitor_test
DB_USER=imonitor_test
DB_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# --- Authentication ---
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# --- Encryption ---
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# --- SMTP (Email Alerts) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=test@example.com
SMTP_FROM_NAME=iMonitorServer Test

# --- Monitoring Agent ---
AGENT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
HEARTBEAT_INTERVAL=30

# --- Bridge Service ---
BRIDGE_URL=http://bridge:3578
BRIDGE_SECRET=CHANGE_ME

# --- Logging ---
LOG_LEVEL=debug
LOG_FORMAT=pretty

# --- Docker Ports (host:container) ---
POSTGRES_EXTERNAL_PORT=5441
REDIS_EXTERNAL_PORT=6381
BACKEND_EXTERNAL_PORT=3099
FRONTEND_EXTERNAL_PORT=8099
