# ===========================================
# iMonitorServer Backend Environment Variables
# ===========================================

# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://imonitor:imonitor_password@localhost:5432/imonitor_db?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Agent
AGENT_HEARTBEAT_TIMEOUT_SECONDS=90
AGENT_HEARTBEAT_INTERVAL_SECONDS=30
