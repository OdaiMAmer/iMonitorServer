# ===========================================
# iMonitorServer - TEST Environment Variables
# ===========================================

# Environment
NODE_ENV=test
COMPOSE_PROJECT_NAME=imonitor-test

# Server
PORT=3000
API_PREFIX=/api/v1

# Database (PostgreSQL)
POSTGRES_DB=imonitor_test_db
POSTGRES_USER=imonitor_test
POSTGRES_PASSWORD=imonitor_test_password_2026
DATABASE_URL=postgresql://imonitor_test:imonitor_test_password_2026@postgres:5432/imonitor_test_db?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_test_secret_2026
REDIS_DB=1

# JWT
JWT_SECRET=iMonitorServer-test-jwt-secret-key-2026-xK9mP2
JWT_ACCESS_EXPIRATION=30m
JWT_REFRESH_EXPIRATION=1d

# CORS
CORS_ORIGIN=http://localhost:8099

# Logging
LOG_LEVEL=debug

# Rate Limiting (relaxed for testing)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=500

# Agent
AGENT_HEARTBEAT_TIMEOUT_SECONDS=90
AGENT_HEARTBEAT_INTERVAL_SECONDS=30

# Exposed Ports (host machine)
FRONTEND_PORT=8099
BACKEND_PORT=3099
POSTGRES_PORT=5440
REDIS_EXPOSED_PORT=6390

# Frontend Build Args
VITE_API_BASE_URL=/api
VITE_WS_URL=
