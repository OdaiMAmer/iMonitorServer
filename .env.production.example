# iMonitorServer — Production Environment
# Copy to .env.production and fill in real values

# Database (use strong, random credentials)
POSTGRES_DB=imonitor_prod
POSTGRES_USER=imonitor_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD

# JWT (generate with: openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64

# Ports
FRONTEND_PORT=443
PORT=3100

# CORS (your actual domain)
CORS_ORIGIN=https://monitor.yourdomain.com

# SSL/TLS (configure your reverse proxy)
# If using nginx/traefik in front, set FRONTEND_PORT=80 and handle SSL there
